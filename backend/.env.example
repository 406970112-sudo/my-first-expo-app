APP_ENV=production

SERVER_HOST=0.0.0.0
SERVER_PORT=3000
SERVER_PUBLIC_BASE_URL=https://api.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

STORAGE_AUDIO_DIR=voice

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=30
MAX_REQUEST_BODY_BYTES=65536

TTS_MAX_TEXT_LENGTH=5000
TTS_MAX_CONTEXT_LENGTH=1000
TTS_REQUEST_TIMEOUT_MS=120000

VOLC_APP_ID=your_app_id
VOLC_ACCESS_TOKEN=your_access_token
VOLC_RESOURCE_ID=seed-tts-2.0
VOLC_ENDPOINT=wss://openspeech.bytedance.com/api/v3/tts/unidirectional/stream
